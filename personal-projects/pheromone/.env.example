# Demo mode is default; real sending must be explicitly enabled.
PHEROMONE_DEMO_MODE=1
PHEROMONE_ENABLE_REAL_NOTIFICATIONS=0

# Postgres (local dev)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pheromone

# vLLM
# Phase 0 only: temporary local mock server (see `backend/mock_vllm_server.py`)
# Replace with the real AMD Developer Cloud vLLM endpoint once provisioned.
VLLM_BASE_URL=http://127.0.0.1:8001
VLLM_QWEN3_32B_MODEL=Qwen/Qwen3-32B
VLLM_QWEN3_8B_MODEL=Qwen/Qwen3-8B
